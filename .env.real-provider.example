# 真实 provider 联调模式：禁止 mock / fallback / AUTO_CREATE_TABLES
APP_ENV=real-provider
DATABASE_URL=sqlite:///data/app.db
AUTO_CREATE_TABLES=false

AGENT_PROVIDER=openai_compatible
AGENT_MODEL=gpt-4.1-mini
AGENT_FALLBACK_TO_MOCK=false
# 必填：请替换为真实 provider 地址
AGENT_API_BASE_URL=https://api.openai.com/v1
# 必填：请替换为真实密钥，不要提交真实值
AGENT_API_KEY=your-real-provider-api-key
