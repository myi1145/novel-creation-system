APP_NAME=novel-creation-system
APP_VERSION=0.15.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./data/app.db
AUTO_CREATE_TABLES=true

AGENT_PROVIDER=openai_compatible
AGENT_MODEL=qwen3-max
AGENT_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AGENT_API_KEY=
AGENT_TIMEOUT_SECONDS=45
AGENT_TEMPERATURE=0.3
AGENT_FALLBACK_TO_MOCK=false
AGENT_LOG_STRING_LIMIT=300
AGENT_LOG_COLLECTION_LIMIT=5
AGENT_MAX_RETRIES=2
AGENT_RETRY_BACKOFF_MS=800
AGENT_RETRY_BACKOFF_MULTIPLIER=2.0
AGENT_RETRY_ON_STATUSES=408,409,429,500,502,503,504
AGENT_ENABLE_RATE_LIMIT=true
AGENT_RATE_LIMIT_PER_MINUTE=30
AGENT_ENABLE_CIRCUIT_BREAKER=true
AGENT_CIRCUIT_FAILURE_THRESHOLD=3
AGENT_CIRCUIT_COOLDOWN_SECONDS=60
AGENT_CIRCUIT_HALF_OPEN_MAX_CALLS=1
