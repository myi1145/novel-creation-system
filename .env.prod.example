# 生产模式：禁止 mock / fallback / AUTO_CREATE_TABLES
APP_ENV=prod
DATABASE_URL=postgresql+psycopg://user:password@db-host:5432/novel_db
AUTO_CREATE_TABLES=false

AGENT_PROVIDER=openai_compatible
AGENT_MODEL=gpt-4.1-mini
AGENT_FALLBACK_TO_MOCK=false
# 必填：请替换为生产 provider 地址
AGENT_API_BASE_URL=https://api.openai.com/v1
# 必填：请通过安全注入，不要把真实 secret 写入仓库
AGENT_API_KEY=your-production-api-key
